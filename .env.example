# ── 資料庫 (TiDB Cloud / MySQL) ──
DB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your_user.root
DB_PASSWORD=your_password
DB_NAME=etf_tracker

# ── JWT 安全金鑰 (務必更換成隨機字串) ──
JWT_SECRET=please-change-to-a-long-random-string-in-production
JWT_EXPIRE_HOURS=168

# ── Google OAuth 2.0 ──
# 前往 https://console.cloud.google.com => API 與服務 => 憑證 => 建立 OAuth 2.0 用戶端 ID
# 授權重新導向 URI: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── 應用程式 ──
APP_URL=http://localhost:8000

# ── 通知 (選填) ──
# LINE_NOTIFY_TOKEN=your_line_notify_token
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your_app_password
