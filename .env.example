# ============================================================
#  ETF 投資系統 — 資料庫設定檔
#  請將本檔案重新命名為 .env 並填入您的 TiDB Cloud 資訊
#  (此 .env.example 不會被程式讀取)
# ============================================================

# ── TiDB Cloud 連線資訊 ──
# 從 TiDB Cloud → Cluster → Connect → MySQL 取得
DB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=xxxxxxxxxx.root
DB_PASSWORD=請填入您的密碼
DB_NAME=etf_tracker

# ── 說明 ──
# DB_HOST  : TiDB Cloud 的連線端點（帶有 tidbcloud.com 時自動啟用 SSL）
# DB_PORT  : 預設 4000（TiDB 標準 MySQL port）
# DB_USER  : 格式通常為 「前綴.root」
# DB_NAME  : 資料庫名稱，第一次啟動會自動建立
